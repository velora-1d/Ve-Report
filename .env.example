# Database
DATABASE_URL="[REDACTED-DATABASE_CONNECTION_STRING]"

# Better Auth (ganti dengan domain production kamu)
BETTER_AUTH_URL="[REDACTED-URL]"
# BETTER_AUTH_TRUSTED_ORIGINS="[REDACTED-URL]"

# Supabase (opsional, hanya jika fitur Supabase aktif)
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""

# S3 / RustFS Object Storage Settings
STORAGE_PROVIDER=RustFS
S3_ENDPOINT="[REDACTED-URL]"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=store
S3_REGION=ap-southeast-1
S3_USE_SSL=true
S3_PATH_STYLE=true
S3_MAX_RETRIES=3
S3_TIMEOUT=30s
S3_PUBLIC_URL="[REDACTED-URL]"
NEXT_PUBLIC_S3_ENDPOINT="[REDACTED-URL]"
NEXT_PUBLIC_S3_BUCKET=store
